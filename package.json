{
  "name": "terminus",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/with-mac-bin.mjs vite",
    "build": "node scripts/with-mac-bin.mjs vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "prepare": "husky",
    "test": "node scripts/with-mac-bin.mjs vitest",
    "test:coverage": "node scripts/with-mac-bin.mjs vitest run --coverage",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:debug": "playwright test --debug",
    "clean": "rimraf node_modules",
    "test:zig": "node scripts/with-mac-bin.mjs sh -c \"cd zig && zig test gpx.zig && zig test trace.zig && zig test simplify.zig && zig test time.zig && zig test gpspoint.zig && zig test extrema.zig && zig test climbs.zig && zig test leg.zig && zig test section.zig && zig test stage.zig && zig test gpxdata.zig && zig test soundscape.zig\"",
    "test:zig:parallel": "cd zig && powershell -c \"$dir = Get-Location; $jobs = @(); @('gpx.zig', 'trace.zig', 'simplify.zig', 'time.zig', 'gpspoint.zig', 'extrema.zig', 'csv.zig') | ForEach-Object { $jobs += Start-Job -ScriptBlock { param($f, $d) Set-Location $d; zig test $f } -ArgumentList $_, $dir }; $jobs | Wait-Job | Receive-Job; $jobs | Remove-Job\"",
    "test:all": "npm run test:zig && npm run test",
    "party": "partykit dev --port 1999"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  },
  "dependencies": {
    "@react-spring/three": "10.0.3",
    "@react-spring/web": "10.0.3",
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.4.2",
    "@styled-icons/feather": "10.47.0",
    "@uidotdev/usehooks": "^2.4.1",
    "d3-array": "3.2.4",
    "d3-scale": "4.0.2",
    "d3-shape": "3.2.0",
    "date-fns": "4.1.0",
    "partysocket": "^1.1.15",
    "polished": "4.3.1",
    "qrcode": "^1.5.4",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-helmet-async": "^3.0.0",
    "react-virtualized-auto-sizer": "1.0.26",
    "satori": "^0.26.0",
    "styled-components": "6.1.19",
    "styled-icons": "10.47.1",
    "three": "0.181.2",
    "unenv": "^2.0.0-rc.0",
    "wouter": "^3.9.0",
    "zustand": "5.0.9"
  },
  "overrides": {
    "serialize-javascript": "7.0.5"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "9.39.1",
    "@playwright/test": "1.57.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "24.10.1",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.1",
    "@vitest/coverage-v8": "^4.0.15",
    "eslint": "9.39.1",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.4.24",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "16.5.0",
    "husky": "9.1.7",
    "jsdom": "27.2.0",
    "lint-staged": "16.2.7",
    "partykit": "^0.0.115",
    "prettier": "3.7.4",
    "r3f-perf": "7.2.3",
    "rimraf": "6.1.2",
    "rollup-plugin-visualizer": "^6.0.5",
    "rollup-plugin-zigar": "0.15.2",
    "vite": "7.2.6",
    "vite-plugin-arraybuffer": "0.1.1",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-pwa": "1.2.0",
    "vitest": "4.0.15"
  }
}

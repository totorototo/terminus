{
  "ci": {
    "collect": {
      "startServerCommand": "npm run preview -- --port 4173",
      "startServerReadyPattern": "Local.*4173",
      "url": [
        "http://localhost:4173/",
        "http://localhost:4173/this-does-not-exist"
      ],
      "numberOfRuns": 1,
      "settings": {
        "chromeFlags": "--no-sandbox --disable-gpu",
        "preset": "desktop"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.3 }],
        "categories:accessibility": ["warn", { "minScore": 0.7 }],
        "first-contentful-paint": ["error", { "maxNumericValue": 8000 }],
        "interactive": ["warn", { "maxNumericValue": 20000 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.25 }],
        "total-blocking-time": ["warn", { "maxNumericValue": 5000 }],
        "uses-text-compression": ["warn", { "minScore": 0 }],
        "no-unload-listeners": ["warn", { "minScore": 0 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
